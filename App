  <script>
    // ==========================================
    // AgriFlo WaterWise Dashboard
    // ==========================================
    
    // Default configuration
    const defaultConfig = {
      system_title: 'AgriFlo WaterWise',
      location_name: 'Smart Irrigation System',
      background_color: '#0a1628',
      surface_color: '#1a2942',
      text_color: '#e8f0f8',
      primary_action: '#10b981',
      secondary_action: '#3b82f6',
      sprinkler_on_temp: '33',
      sprinkler_off_temp: '31.5'
    };
    
    // Current state
    let currentLogs = [];
    let simulatedState = {
      temperature: 28.5,
      humidity: 65,
      sprinkler_active: false,
      nipple_active: false,
      cleaning_active: false,
      water_ok: true
    };
    
    // Toast notification
    function showToast(message, type = 'success') {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      toast.className = 'toast';
      toast.style.background = type === 'success' ? '#10b981' : type === 'error' ? '#ef4444' : '#3b82f6';
      toast.style.color = 'white';
      toast.textContent = message;
      container.appendChild(toast);
      
      setTimeout(() => {
        toast.style.opacity = '0';
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }
    
    // Update time display
    function updateTime() {
      const now = new Date();
      const timeStr = now.toLocaleTimeString('en-US', { hour12: false });
      document.getElementById('current-time').textContent = timeStr;
    }
    setInterval(updateTime, 1000);
    updateTime();
    
    // Simulate sensor data variations
    function simulateSensorData() {
      // Small random variations to simulate real sensor behavior
      simulatedState.temperature += (Math.random() - 0.5) * 0.5;
      simulatedState.temperature));
      
      simulatedState.humidity += (Math.random() - 0.5) * 2;
      simulatedState.humidity = Math.max(30, Math.min(90, simulatedState.humidity));
      
      updateSensorDisplay();
    }
    
    // Update sensor displays
    function updateSensorDisplay() {
      const tempEl = document.getElementById('temp-value');
      const humEl = document.getElementById('humidity-value');
      const tempBar = document.getElementById('temp-bar');
      const humBar = document.getElementById('humidity-bar');
      
      const temp = simulatedState.temperature.toFixed(1);
      const hum = simulatedState.humidity.toFixed(0);
      
      tempEl.textContent = temp;
      humEl.textContent = hum;
      // Update bars (0-50°C range for temp, 0-100% for humidity)
      const tempPercent = Math.min(100, Math.max(0, (simulatedState.temperature / 50) * 100));
      const humPercent = Math.min(100, Math.max(0, simulatedState.humidity));
      
      tempBar.style.height = `${tempPercent}%`;
      humBar.style.height = `${humPercent}%`;
      
      // Color coding for temperature
      if (simulatedState.temperature >= 33) {
        tempEl.style.color = '#ef4444';
      } else if (simulatedState.temperature >= 30) {
        tempEl.style.color = '#f59e0b';
      } else {
        tempEl.style.color = '#10b981';
      }
    }
    
    // Update relay UI
    function updateRelayUI() {
      // Nipple
      const nippleStatus = document.getElementById('nipple-status');
      const nippleIndicator = document.getElementById('nipple-indicator');
      const nippleCard = document.getElementById('relay-nipple-card');
      
      if (simulatedState.nipple_active) {
        nippleStatus.textContent = 'ON';
        nippleStatus.className = 'text-sm font-medium text-green-400';
        nippleIndicator.className = 'w-4 h-4 rounded-full bg-green-500 pulse-dot';
        nippleCard.classList.add('glow-green');
      } else {
        nippleStatus.textContent = 'OFF';
        nippleStatus.className = 'text-sm font-medium text-gray-400';
        nippleIndicator.className = 'w-4 h-4 rounded-full bg-gray-600';
        nippleCard.classList.remove('glow-green');
      }
      // Sprinkler
      const sprinklerStatus = document.getElementById('sprinkler-status');
      const sprinklerIndicator = document.getElementById('sprinkler-indicator');
      const sprinklerCard = document.getElementById('relay-sprinkler-card');
      
      if (simulatedState.sprinkler_active) {
        sprinklerStatus.textContent = 'ON';
