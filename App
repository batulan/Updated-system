    // Render logs table
    function renderLogs(logs) {
      const tbody = document.getElementById('logs-table');
      const logCount = document.getElementById('log-count');
      const logInfo = document.getElementById('log-info');
      
      logCount.textContent = logs.length;
      logInfo.textContent = logs.length > 0 ? `${logs.length} entries` : 'No logs yet';===&& && && && && && && && 
      if (logs.length === 0) {
        tbody.innerHTML = `
          <tr id="no-logs-row">
            <td colspan="7" class="py-8 text-center opacity-50">
              No logs recorded yet. Click "Log Current Reading" to start.
            </td>
          </tr>
        `;
        return;
      }
      
      // Sort by timestamp descending (newest first)
      const sortedLogs = [...logs].sort((a, b) => {
        return new Date(b.timestamp) - new Date(a.timestamp);
      });
      
      tbody.innerHTML = sortedLogs.slice(0, 20).map(log => {
        const date = new Date(log.timestamp);
        const timeStr = date.toLocaleString();
        return `
          <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
            <td class="py-3 pr-4 text-xs">${timeStr}</td>
            <td class="py-3 pr-4">${log.temperature?.toFixed(1) || '--'}</td>
