                ${log.sprinkler_active ? 'ON' : 'OFF'}
              </span>
            </td>
            <td class="py-3 pr-4">
              <span class="px-2 py-1 rounded text-xs ${log.nipple_active ? 'bg-green-500/20 text-green-400' : 'bg-gray-500/20 text-gray-400'}">
                ${log.nipple_active ? 'ON' : 'OFF'}
              </span>
            </td>
            <td class="py-3 pr-4">
            <span class="px-2 py-1 rounded text-xs ${log.cleaning_active ? 'bg-yellow-500/20 text-yellow-400' : 'bg-gray-500/20 text-gray-400'}">
                ${log.cleaning_active ? 'ON' : 'OFF'}
              </span>
            </td>
            <td class="py-3">
